
# GEMINI_API_KEY: Required for Gemini AI API calls (Google AI).
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# AGMARKNET_API_KEY: Required for Agmarknet crop price API (https://api.data.gov.in/).
AGMARKNET_API_KEY="MY_AGMARKNET_API_KEY"

# WHISPER_API_KEY: For speech-to-text (if using Whisper or external service).
WHISPER_API_KEY="MY_WHISPER_API_KEY"

# AWS_POLLY_API_KEY: For text-to-speech (if using AWS Polly).
AWS_POLLY_API_KEY="MY_AWS_POLLY_API_KEY"

# SKILL_API_KEY: For external skill program APIs (if available).
SKILL_API_KEY="MY_SKILL_API_KEY"

# JWT_SECRET: For user authentication and token signing.
JWT_SECRET="MY_JWT_SECRET"

# APP_URL: The URL where this applet is hosted (for cloud deployment).
APP_URL="MY_APP_URL"

# DB_URL: For cloud database connection (PostgreSQL, DynamoDB, etc.).
DB_URL="MY_DB_URL"

# S3_BUCKET: For cloud storage (AWS S3, GCP Storage).
S3_BUCKET="MY_S3_BUCKET"
