# ===========================================
# SathiAI Backend - Environment Variables
# Copy to .env and fill in your keys.
# ===========================================

# --- AWS (Bedrock, Polly, Transcribe, DynamoDB, S3) ---
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=ap-south-1

# Bedrock: AI chat (Claude). Example: anthropic.claude-3-haiku-20240307-v1:0
AWS_BEDROCK_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0

# S3: Certificates, assets (optional)
AWS_S3_BUCKET=sathiai-assets

# DynamoDB table names (optional; defaults used if not set)
# DYNAMO_USERS_TABLE=SathiAI_Users
# DYNAMO_SCHEMES_TABLE=SathiAI_Schemes
# DYNAMO_OTPS_TABLE=SathiAI_OTPs
# DYNAMO_MARKET_TABLE=SathiAI_MarketData

# --- Live data / Web scraping ---
# data.gov.in: Agri market prices (https://api.data.gov.in). Get key at https://data.gov.in
DATA_GOV_IN_API_KEY=

# Optional: Agmarknet / other market API
# AGMARKNET_API_KEY=

# Optional: Schemes from JSON API (GET returns list or { schemes: [] })
# SCHEMES_API_URL=https://example.com/schemes.json
# Optional: Schemes listing page to scrape (HTML)
# SCHEMES_SCRAPE_URL=https://www.myscheme.gov.in/schemes

# --- Auth & push ---
JWT_SECRET=your_jwt_secret_min_32_chars
# FCM_SERVER_KEY=  # Firebase Cloud Messaging for push notifications

# --- Optional: Email (SES / SMTP) ---
# SES_SOURCE_EMAIL=
# EMAIL_USER=
# EMAIL_PASS=

# --- Optional: External AI / STT / TTS ---
# GEMINI_API_KEY=
# WHISPER_API_KEY=
# AWS Polly uses same AWS_* keys above
