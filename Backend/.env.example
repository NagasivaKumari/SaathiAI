
# =============================
# SathiAI Backend - .env Example
# =============================

# --- AWS Credentials ---
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=ap-south-1

# --- Bedrock AI Model ---
AWS_BEDROCK_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0

# --- S3 Bucket (for assets, certificates) ---
AWS_S3_BUCKET=sathiai-assets

# --- DynamoDB Table Names (optional, defaults used if not set) ---
# DYNAMO_USERS_TABLE=SathiAI_Users
# DYNAMO_SCHEMES_TABLE=SathiAI_Schemes
# DYNAMO_OTPS_TABLE=SathiAI_OTPs
# DYNAMO_MARKET_TABLE=SathiAI_MarketData

# --- Data Sources ---
DATA_GOV_IN_API_KEY=your_data_gov_in_api_key
# AGMARKNET_API_KEY=your_agmarknet_api_key
# SCHEMES_API_URL=https://example.com/schemes.json
# SCHEMES_SCRAPE_URL=https://www.myscheme.gov.in/schemes

# --- Auth & Push Notifications ---
JWT_SECRET=your_jwt_secret_min_32_chars
# FCM_SERVER_KEY=your_firebase_cloud_messaging_key

# --- Email (SES/SMTP, optional) ---
# SES_SOURCE_EMAIL=your_verified_email@domain.com

# --- Any other secrets or API keys ---
# Add as needed for future integrations
# EMAIL_USER=
# EMAIL_PASS=

# --- Optional: External AI / STT / TTS ---
# GEMINI_API_KEY=
# WHISPER_API_KEY=
# AWS Polly uses same AWS_* keys above
